# OpenAI (required for extraction, embeddings, chat)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# MongoDB (required)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=smart_invoice

# Neo4j (optional — Graph RAG / relationship queries disabled if empty)
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Docling microservice (optional — PDFs use it when set; otherwise local extractors)
# Run: cd docling_service && uvicorn app.main:app --host 0.0.0.0 --port 8765
# API keys: leave both empty for no auth (default). Set DOCLING_API_KEY on the docling service + same value here only if you lock it down.
DOCLING_SERVICE_URL=http://127.0.0.1:8765
DOCLING_SERVICE_API_KEY=
DOCLING_POLL_INTERVAL_SEC=1.5
DOCLING_JOB_TIMEOUT_SEC=900

# MongoDB Atlas Vector Search ONLY (not available on self-hosted / Compass-only local MongoDB).
# Compass cannot create this: build the index in Atlas UI → Database → your cluster → Search → Create search index (vector) on `invoices.embedding`.
# Leave empty to use in-app cosine similarity (works everywhere).
ATLAS_VECTOR_INDEX_NAME=
ATLAS_VECTOR_NUM_CANDIDATES=150

# Due-date alerts: APScheduler runs daily 08:00 UTC + once at startup; optional webhook for new rows
SCHEDULER_ENABLED=true
DUE_ALERT_DAYS_AHEAD=7
ALERT_WEBHOOK_URL=

# App
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_MB=25
LOG_LEVEL=INFO
